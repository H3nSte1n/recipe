# Copy to .env (gitignored) and set strong, unique values. Do not commit the
# real file.

# Used by docker-compose.yml for both the Postgres server and the backend's
# DB_PASSWORD.
DB_PASSWORD=change_me_to_a_strong_unique_password

# Only consumed by docker-compose.prod.yml (see that file's app.environment).
# Required in production — the backend refuses to boot without a strong
# JWT_SECRET, and encryption of stored AI API keys requires a non-empty
# SECURITY_ENCRYPTION_KEY. Generate both with e.g. `openssl rand -hex 32`.
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_bytes
SECURITY_ENCRYPTION_KEY=change_me_to_a_strong_random_secret

# Optional in production — leave blank to ship with email verification/reset
# and AI-powered recipe import inert until real values are set.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
