# Baked into the production image as env.production.yaml (see Dockerfile.prod).
# Contains no secrets: every sensitive field below is a placeholder that is
# overridden at container start by the matching environment variable (see
# pkg/config/config.go secretKeys list). The app refuses to boot if a secret
# is left at its placeholder value — see Config.Validate().
app:
  name: recipe-app
  env: production
  port: 8080

frontend:
  url: https://recipe.steinhauer.dev

db:
  host: db
  port: 5432
  user: postgres
  password: CHANGE_ME # overridden by DB_PASSWORD
  name: recipe_db
  ssl_mode: disable

jwt:
  secret: CHANGE_ME # overridden by JWT_SECRET
  duration: 24h
  issuer: recipe-app
  audience: recipe-app-api
  expiration_hours: 24h

smtp:
  host: smtp.gmail.com
  port: 587
  user: CHANGE_ME
  password: CHANGE_ME # overridden by SMTP_PASSWORD
  from: CHANGE_ME

storage:
  type: local
  local_path: ./uploads
  base_url: https://recipe.steinhauer.dev/uploads
  aws:
    region: us-east-1
    bucket: unused
    access_key_id: unused
    secret_access_key: unused

ai:
  openai_api_key: CHANGE_ME # overridden by AI_OPENAI_API_KEY
  anthropic_api_key: CHANGE_ME # overridden by AI_ANTHROPIC_API_KEY

security:
  encryption_key: CHANGE_ME # overridden by SECURITY_ENCRYPTION_KEY

cors:
  allowed_origins:
    - https://recipe.steinhauer.dev

log_level: info
