app:
  name: recipe-app
  env: development
  port: 8080

frontend:
  url: localhost:5173

db:
  host: db
  port: 5432
  user: postgres
  password: your_password
  name: recipe_db
  ssl_mode: disable

jwt:
  # REQUIRED: the server refuses to boot if this is empty, a known placeholder,
  # or shorter than 32 bytes. Generate one (e.g. `openssl rand -base64 48`) and
  # inject it in production via the JWT_SECRET environment variable.
  secret: CHANGE_ME
  duration: 24h
  expiration_hours: 24h

smtp:
  host: smtp.gmail.com
  port: 587
  user: your-email@gmail.com
  password: your-app-specific-password
  from: your-email@gmail.com

storage:
  type: local
  local_path: ./uploads
  base_url: http://localhost:8080/uploads
  aws:
    region: us-east-1
    bucket: your-bucket
    access_key_id: your-aws-key
    secret_access_key: your-aws-secret

ai:
  openai_api_key: your_openai_api_key
  anthropic_api_key: your_anthropic_api_key

# Application-layer encryption key for secrets at rest (user AI API keys).
# Required — the server refuses to start without it. Use a long random value and
# inject it in production via the SECURITY_ENCRYPTION_KEY environment variable
# rather than committing it. Any non-empty passphrase works (it is hashed to a
# 32-byte AES-256 key).
security:
  encryption_key: change-me-to-a-long-random-secret

cors:
  allowed_origins:
    - http://localhost:5173

log_level: debug